# Twilio Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # E.164, e.g. +1XXXXXXXXXX
ADVISOR_PHONE_NUMBER=        # birthday digest recipient (E.164), e.g. your personal phone

# SMS Panel module — single fixed recipient
TARGET_PHONE_NUMBER=         # optional direct-text recipient. Falls back to ADVISOR_PHONE_NUMBER.

# Upstash Redis REST Credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Security Keys Gating Dashboard and Cron Access
CRON_SECRET=                 # random string, used by Vercel Cron Authorization header
APP_ACCESS_KEY=

# Public base URL — used to build the Twilio statusCallback URL and to validate
# inbound webhook signatures (e.g. https://your-app.vercel.app). If unset,
# signature validation derives the URL from forwarded headers and no
# statusCallback is attached to outbound messages.
PUBLIC_BASE_URL=
